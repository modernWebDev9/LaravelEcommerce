{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The skeleton starter kit for Shopper.",
  "keywords": [
    "laravel",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "darryldecode/cart": "^4.2.6",
    "diglactic/laravel-breadcrumbs": "^10.0",
    "filament/support": ">=4.7.1",
    "guzzlehttp/guzzle": "^7.10",
    "laravel/framework": "^12.52.0",
    "laravel/tinker": "^2.11.1",
    "laravelcm/livewire-slide-overs": "^1.1.1",
    "livewire/flux": "^2.12.1",
    "livewire/livewire": "^3.7.10",
    "livewire/volt": "^1.10.2",
    "notchpay/notchpay-php": "^1.6.1",
    "shopper/framework": ">=2"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.0.9",
    "driftingly/rector-laravel": ">=2.1.9",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.9.2",
    "laravel/boost": "^2.1.7",
    "laravel/breeze": "^2.3.8",
    "laravel/pint": "^1.27.1",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.1",
    "pestphp/pest": "^4.4.1",
    "pestphp/pest-plugin-laravel": "^4.0",
    "spatie/laravel-ignition": "^2.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@php artisan clear",
      "@update:requirements"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "update:requirements": [
      "composer bump",
      "npx npm-check-updates -u"
    ],
    "lint": [
      "rector",
      "pint --parallel"
    ],
    "refactor": "./vendor/bin/rector",
    "test:lint": [
      "pint --parallel --test",
      "rector --dry-run"
    ],
    "test:refactor": "./vendor/bin/rector --dry-run",
    "test:pest": "pest --parallel",
    "test:types": "phpstan analyse --memory-limit=-1",
    "test": [
      "@test:types",
      "@test:pest"
    ]
  },
  "repositories": [
    {
      "type": "path",
      "url": "../shopper/packages/*"
    }
  ],
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
