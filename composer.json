{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The skeleton starter kit for Shopper.",
  "keywords": [
    "laravel",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "diglactic/laravel-breadcrumbs": "^10.0",
    "guzzlehttp/guzzle": "^7.10",
    "laravel/framework": "^12.53.0",
    "laravel/octane": "^2.14.0",
    "laravel/tinker": "^2.11.1",
    "laravelcm/livewire-slide-overs": "^1.1.1",
    "livewire/flux": "^2.12.2",
    "livewire/livewire": "^3.7.10",
    "livewire/volt": "^1.10.3",
    "mews/purifier": "^3.4.3",
    "notchpay/notchpay-php": "^2.0",
    "shopper/framework": "^2.5",
    "shopper/stripe": "^2.5"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.0.9",
    "driftingly/rector-laravel": ">=2.1.9",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.9.2",
    "laravel/boost": "^2.2.1",
    "laravel/breeze": "^2.3.8",
    "laravel/pint": "^1.27.1",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.1",
    "pestphp/pest": "^4.4.1",
    "pestphp/pest-plugin-laravel": "^4.1",
    "spatie/laravel-ignition": "^2.11",
    "wikimedia/composer-merge-plugin": ">=2.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@php artisan clear",
      "@update:requirements"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "update:requirements": [
      "composer bump",
      "npx npm-check-updates -u"
    ],
    "setup": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --ansi",
      "@php artisan db:seed --ansi",
      "@php artisan storage:link --ansi"
    ],
    "lint": [
      "rector",
      "pint --parallel"
    ],
    "refactor": "./vendor/bin/rector",
    "test:lint": [
      "pint --parallel --test",
      "rector --dry-run"
    ],
    "test:refactor": "./vendor/bin/rector --dry-run",
    "test:pest": "pest --parallel",
    "test:types": "phpstan analyse --memory-limit=-1",
    "test": [
      "@test:types",
      "@test:pest"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    },
    "merge-plugin": {
      "include": [
        "composer.local.json"
      ],
      "replace": true,
      "merge-extra": false
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true,
      "wikimedia/composer-merge-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
